local speed, infJump, noclip, aim, fly, fogFix, invisible, esp = false, false, false, false, false, false, false, false
local flySpeed = 50
local bv

local function createToggle(text, pos, callback)
    local btn = Instance.new("TextButton", MainFrame)
    btn.Size = UDim2.new(0, 240, 0, 45)
    btn.Position = pos
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    btn.Text = "  " .. text
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.Gotham
    btn.TextXAlignment = Enum.TextXAlignment.Left
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
    
    local status = Instance.new("TextLabel", btn)
    status.Size = UDim2.new(0, 50, 1, 0)
    status.Position = UDim2.new(1, -55, 0, 0)
    status.Text = "❌"
    status.BackgroundTransparency = 1
    
    btn.MouseButton1Click:Connect(function()
        local active = callback()
        status.Text = active and "✅" or "❌"
        btn.BackgroundColor3 = active and Color3.fromRGB(0, 100, 200) or Color3.fromRGB(40, 40, 40)
    end)
end

createToggle("Chạy nhanh", UDim2.new(0, 20, 0, 30), function() speed = not speed return speed end)
createToggle("Nhảy vô hạn", UDim2.new(0, 20, 0, 85), function() infJump = not infJump return infJump end)
createToggle("Xuyên tường", UDim2.new(0, 20, 0, 140), function() noclip = not noclip return noclip end)
createToggle("Aim Bot", UDim2.new(0, 20, 0, 195), function() aim = not aim return aim end)
createToggle("Fix Lag (Minimal)", UDim2.new(0, 20, 0, 250), function() 
    fogFix = not fogFix
    Lighting.FogEnd = fogFix and 999999 or 1000
    Lighting.FogStart = fogFix and 999999 or 0
    Lighting.GlobalShadows = not fogFix
    if workspace:FindFirstChild("Clouds") then workspace.Clouds.Enabled = not fogFix end
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Fire") or v:IsA("Smoke") or v:IsA("Explosion") or v:IsA("Sparkles") or v:IsA("Beam") or v:IsA("PostEffect") then v.Enabled = not fogFix end
        if v:IsA("BasePart") then v.CastShadow = not fogFix end
    end
    workspace.Terrain.Decoration = not fogFix
    return fogFix 
end)
createToggle("Bay", UDim2.new(0, 20, 0, 305), function() 
    fly = not fly
    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if fly and root then
        bv = Instance.new("BodyVelocity", root)
        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bv.Velocity = Vector3.new(0, 0, 0)
        player.Character.Humanoid:ChangeState(Enum.HumanoidStateType.Physics)
    elseif bv then bv:Destroy() player.Character.Humanoid:ChangeState(Enum.HumanoidStateType.GettingUp) end
    return fly 
end)
createToggle("Tàng hình", UDim2.new(0, 20, 0, 360), function()
    invisible = not invisible
    local char = player.Character
    if char then
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") or v:IsA("Decal") then v.Transparency = invisible and 1 or 0 end
            if v:IsA("Accessory") then for _, p in pairs(v:GetDescendants()) do if p:IsA("BasePart") then p.Transparency = invisible and 1 or 0 end end end
        end
    end
    return invisible
end)
createToggle("Hào quang (ESP)", UDim2.new(0, 20, 0, 415), function()
    esp = not esp
    local function applyHighlight(target)
        if target.Character and not target.Character:FindFirstChild("PlayerHighlight") then
            local h = Instance.new("Highlight", target.Character)
            h.Name = "PlayerHighlight"
            h.FillColor = Color3.fromRGB(0, 255, 255)
            h.OutlineColor = Color3.fromRGB(255, 255, 255)
            h.FillTransparency = 0.5
            h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        end
    end
    if esp then
        for _, p in pairs(game.Players:GetPlayers()) do if p ~= player then applyHighlight(p) end end
    else
        for _, p in pairs(game.Players:GetPlayers()) do if p.Character and p.Character:FindFirstChild("PlayerHighlight") then p.Character.PlayerHighlight:Destroy() end end
    end
    return esp
end)

RunService.Heartbeat:Connect(function()
    if player.Character and player.Character:FindFirstChild("Humanoid") then player.Character.Humanoid.WalkSpeed = speed and 100 or 16 end
    if fly and bv and player.Character:FindFirstChild("HumanoidRootPart") then
        local cam = workspace.CurrentCamera
        local moveDir = Vector3.new(0,0,0)
        if UIS:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + cam.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - cam.CFrame.LookVector end
        if UIS:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - cam.CFrame.RightVector end
        if UIS:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + cam.CFrame.RightVector end
        bv.Velocity = moveDir * flySpeed
    end
end)

